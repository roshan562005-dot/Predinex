# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local database files (production uses Supabase)
*.db
*.db-shm
*.db-wal

# cloudflare tunnel binary
cloudflared.exe
cloudflare.log

# dev log/debug files
*.log
*.txt
dev_error.log

# build artifacts & scripts
build.log
lint_results.json
eslint.json
check_syntax.py
remove_ai.py
generate_presentation.js
test-db.js
